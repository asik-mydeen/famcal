      "Bash(podman *)",
      "Bash(cargo *)",
      "Bash(python3 *)",
      "Bash(pip3 *)",
      "Bash(uv *)",
      "Bash(mise *)",
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(find *)",
      "Bash(grep *)",
      "Bash(rg *)",
      "Bash(which *)",
      "Bash(echo *)",
      "Bash(wc *)",
      "Bash(head *)",
      "Bash(tail *)",
      "Bash(diff *)",
